#!/usr/bin/env bash
# examples/kitty/claude-with-sentry
# Opens Claude + claude-sentry in a single Kitty window (vsplit).
# Auto-links the sentry pane to the session that the claude pane creates,
# via a SessionStart hook that writes session_id → state file keyed by UUID.

set -e

KITTY_BIN="/Applications/kitty.app/Contents/MacOS/kitty"
TMPDIR_BASE="/tmp/claude-with-sentry-$$"

mkdir -p "$TMPDIR_BASE"

# Generate UUID to link this sentry pane to the Claude session it watches.
# Hook reads CLAUDE_SENTRY_LINK_ID, writes session_id to:
#   ~/.claude/state/sentry-links/<UUID>.json
SENTRY_LINK_ID=$(uuidgen | tr '[:upper:]' '[:lower:]')
STATE_DIR="$HOME/.claude/state/sentry-links"
STATE_FILE="$STATE_DIR/$SENTRY_LINK_ID.json"
mkdir -p "$STATE_DIR"

# Snapshot env vars both panes should inherit. Each is only forwarded if it's
# actually set in your shell — entries that aren't set are silently skipped,
# so it's safe to extend this list with anything Claude needs from your shell
# that wouldn't otherwise reach a freshly-spawned child shell.
#   ANTHROPIC_MODEL                       — only if you pin a non-default model
#   HTTP_PROXY / HTTPS_PROXY / ALL_PROXY  — only if you're behind a proxy
#   *_proxy (lowercase variants)          — same, for tools that read lowercase
# If you use Vertex AI, a custom CA bundle, NVM for node, etc., add those
# variable names here too.
ENV_FILE="$TMPDIR_BASE/env.sh"
{
    echo "#!/bin/zsh"
    echo "export PATH=$HOME/.local/bin:\$PATH"
    for var in ANTHROPIC_MODEL \
               HTTP_PROXY HTTPS_PROXY ALL_PROXY \
               http_proxy https_proxy all_proxy; do
        val="${!var}"
        [[ -n "$val" ]] && printf 'export %s=%q\n' "$var" "$val"
    done
    printf 'export CLAUDE_SENTRY_LINK_ID=%q\n' "$SENTRY_LINK_ID"
} > "$ENV_FILE"

# Claude launcher — runs claude --verbose directly. SessionStart hook fires at
# process start, capturing session_id for the sentry pane to pick up.
# (No bootstrap step: would race with the real session and confuse the sentry
# pane, which has no signal-based re-link mechanism like the old sidebar.)
CLAUDE_LAUNCHER="$TMPDIR_BASE/run-claude.sh"
{
    echo "#!/bin/zsh"
    echo "source '$ENV_FILE'"
    echo "for i in \$(seq 1 20); do cols=\$(tput cols 2>/dev/null || echo 0); [ \"\$cols\" -gt 20 ] && break; sleep 0.5; done"
    if [[ $# -eq 0 ]]; then
        echo "claude --verbose"
    else
        printf 'claude %s\n' "$(printf '%q ' "$@")"
    fi
    echo "echo '[Claude exited — press Enter to close]'"
    echo "read"
    printf "rm -f %q\n" "$STATE_FILE"
} > "$CLAUDE_LAUNCHER"
chmod +x "$CLAUDE_LAUNCHER"

# Sentry launcher: wait for SessionStart hook to write session_id, then attach.
# Times out after 15s and falls back to --all-sessions so the pane is never blank.
SENTRY_LAUNCHER="$TMPDIR_BASE/run-sentry.sh"
{
    echo "#!/bin/zsh"
    echo "source '$ENV_FILE'"
    echo "for i in \$(seq 1 20); do cols=\$(tput cols 2>/dev/null || echo 0); [ \"\$cols\" -gt 20 ] && break; sleep 0.5; done"
    cat << SENTRY
echo "⏳ Waiting for Claude session to start..."
SESSION_ID=""
for i in \$(seq 1 30); do
    if [[ -f "$STATE_FILE" ]]; then
        SESSION_ID=\$(python3 -c "import json; print(json.load(open('$STATE_FILE')).get('session_id',''))" 2>/dev/null)
        [[ -n "\$SESSION_ID" ]] && break
    fi
    sleep 0.5
done
if [[ -n "\$SESSION_ID" ]]; then
    echo "🔗 Linked to session: \$SESSION_ID"
    ~/.local/bin/claude-sentry --session "\$SESSION_ID"
else
    echo "⚠️  Timeout waiting for session — falling back to --all-sessions"
    ~/.local/bin/claude-sentry --all-sessions
fi
echo "[Sentry exited with code \$? — press Enter to close]"
read
SENTRY
} > "$SENTRY_LAUNCHER"
chmod +x "$SENTRY_LAUNCHER"

# Build Kitty session file
SESSION_FILE="$TMPDIR_BASE/session.conf"
cat > "$SESSION_FILE" << SESS
new_tab
layout splits
launch --title "Claude Main" /bin/zsh "$CLAUDE_LAUNCHER"
launch --title "Claude Sentry" --location vsplit --bias 35 /bin/zsh "$SENTRY_LAUNCHER"
SESS

# Open Kitty with the session
"$KITTY_BIN" --single-instance --session "$SESSION_FILE" 2>/dev/null &

# Clean up tmp files after Kitty has read the session
sleep 5 && rm -rf "$TMPDIR_BASE" &

echo "✅ Kitty window opened with Claude + claude-sentry (link id: $SENTRY_LINK_ID)"
